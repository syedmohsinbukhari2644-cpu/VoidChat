{
  "expo": {
    "name": "VOID CHAT",
    "slug": "void-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.voidchat.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_CONTACTS"
      ],
      "navigationBar": {
        "visible": "sticky-immersive",
        "backgroundColor": "#000000"
      },
      "statusBar": {
        "translucent": true,
        "backgroundColor": "#00000000"
      }
    },
    "scheme": "voidchat",
    "web": {
      "bundler": "metro",
      "output": "static",
      "shortName": "VOID CHAT",
      "themeColor": "#000000",
      "backgroundColor": "#000000",
      "display": "standalone"
    },
    "extra": {
      "eas": {
        "projectId": "44be8895-6567-4eb3-a787-4fbe60a20ebd"
      }
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "enableMinifyInReleaseBuilds": false,
            "enableShrinkResourcesInReleaseBuilds": false
          }
        }
      ],
      "@config-plugins/react-native-webrtc",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them in chats.",
          "cameraPermission": "The app accesses your camera to let you take photos for chats."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "The app accesses your contacts to invite friends."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "The app accesses your location to share with friends.",
          "locationWhenInUsePermission": "The app accesses your location to share with friends."
        }
      ]
    ]
  }
}
